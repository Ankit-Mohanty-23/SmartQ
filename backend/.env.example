# Server Configuration
NODE_ENV=development
PORT=5000

# Database (Docker Compose uses these to configure both the db service and backend container)
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=smartq

# Admin Seeding Details
ADMIN_NAME='Your Admin Name'
ADMIN_EMAIL='admin@example.com'
ADMIN_PASSWORD='your_admin_password'

# URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Security Configuration
JWT_SECRET=your_jwt_secret_here

# Image Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# BREVO Email Configuration
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
CLIENT_URL="http://localhost:5000/"

# Database URL
# For local dev: uses localhost
# Docker sets this automatically via docker-compose.yml using DB_* vars above
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}"

# ML Service
ML_SERVICE_URL="https://your-ml-service-url.hf.space"

# Weather API Configuration (OpenWeatherMap)
WEATHER_API_KEY="your_openweathermap_api_key"
HOSPITAL_CITY="Your City"

# Redis Configuration
REDIS_URL=redis://localhost:6379