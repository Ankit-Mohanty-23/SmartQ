// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AppointmentStatus {
  PENDING       
  CONFIRMED      
  REJECTED       
  CANCELLED     
  EXPIRED      
}

//////////////////////////////////////////////////
// USER MODEL (Doctors, Admin, Receptionist)
//////////////////////////////////////////////////

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role

  // Doctor fields (nullable for non-doctors)
  workStartTime String?  // "09:00"
  workEndTime   String?  // "17:00"
  averageConsultationMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorQueues        Queue[]              @relation("DoctorQueue")
  appointmentRequests AppointmentRequest[] @relation("DoctorAppointmentRequests")
  payments            Payment[]            @relation("PaymentHandledBy")

  @@map("users")
}

//////////////////////////////////////////////////
// PATIENT MODEL
//////////////////////////////////////////////////

model Patient {
  id          String   @id @default(uuid())
  name        String
  dateOfBirth DateTime
  gender      Gender
  phone       String   @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  queues      Queue[]
  payments    Payment[]

  @@index([phone])
  @@map("patients")
}

//////////////////////////////////////////////////
// QUEUE MODEL
//////////////////////////////////////////////////

model Queue {
  id String @id @default(uuid())

  tokenNumber Int
  status      QueueStatus @default(WAITING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   User   @relation("DoctorQueue", fields: [doctorId], references: [id], onDelete: Cascade)

  visitDate DateTime

  estimatedStartTime DateTime?
  estimatedEndTime   DateTime?

  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@index([visitDate])
  @@index([createdAt])
  @@map("queues")
}

//////////////////////////////////////////////////
// PAYMENT MODEL
//////////////////////////////////////////////////

model Payment {
  id String @id @default(uuid())

  amount Float

  handledById String
  handledBy   User @relation("PaymentHandledBy", fields: [handledById], references: [id], onDelete: Cascade)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([handledById])
  @@index([createdAt])
  @@map("payments")
}

model AppointmentRequest {
  id          String   @id @default(uuid())

  name        String
  phone       String
  problem     String
  preferredDate DateTime

  status      AppointmentStatus @default(PENDING)

  assignedDoctorId String?
  assignedDoctor   User? @relation("DoctorAppointmentRequests", fields: [assignedDoctorId], references: [id])

  createdAt   DateTime @default(now())

  @@map("appointment_requests")
}