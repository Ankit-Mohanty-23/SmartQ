generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AgeGroup {
  CHILD
  ADULT
  SENIOR
}

enum VisitType {
  NEW
  FOLLOW_UP
  EMERGENCY
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  EXPIRED
}

enum TimeSlot {
  MORNING
  AFTERNOON
  EVENING
}

enum WeatherCondition {
  SUNNY_NORMAL
  SUNNY_HOT
  SUNNY_EXTREME_HEAT
  CLOUDY_NORMAL
  CLOUDY_HOT
  RAINING_NORMAL
  HUMIDITY
  HEAVY_RAIN_NORMAL
  CYCLONE_WARNING
  UNKNOWN
}

enum FallbackType {
  MODEL
  CORRECTION_ENGINE
  DOCTOR_AVERAGE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorProfile         DoctorProfile?
  convertedAppointments AppointmentRequest[] @relation("ConvertedByReceptionist")

  @@map("users")
}

model DoctorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  specialization             String
  workStartTime              String
  workEndTime                String
  averageConsultationMinutes Int    @default(15)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queues               Queue[]
  correctionFactors    CorrectionFactor[]
  loadHistory          DailyLoadHistory[]
  assignedAppointments AppointmentRequest[] @relation("AssignedDoctor")

  @@map("doctor_profiles")
}

model Queue {
  id String @id @default(uuid())

  tokenNumber     Int
  appointmentDate DateTime    @db.Date
  status          QueueStatus @default(WAITING)

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Restrict)

  patientName   String
  patientPhone  String
  patientAge    Int
  ageGroup      AgeGroup
  patientGender Gender
  visitType     VisitType

  timeSlot                 TimeSlot
  predictedDurationMinutes Float
  mlConfidenceScore        Float?
  fallbackUsed             FallbackType @default(DOCTOR_AVERAGE)

  estimatedStartTime DateTime
  estimatedEndTime   DateTime

  actualStartTime       DateTime?
  actualEndTime         DateTime?
  actualDurationMinutes Float?

  isDrifting                Boolean          @default(false)
  isOutlierExcluded         Boolean          @default(false)
  earlyWarningSent          Boolean          @default(false)
  lastNotifiedEstimatedTime DateTime?
  weatherCondition          WeatherCondition @default(UNKNOWN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointmentRequest AppointmentRequest? @relation("TokenFromAppointment")

  @@unique([doctorProfileId, appointmentDate, tokenNumber])
  @@index([doctorProfileId, appointmentDate, status])
  @@index([status, estimatedEndTime])
  @@index([patientPhone, doctorProfileId, appointmentDate])
  @@index([isOutlierExcluded, actualDurationMinutes])
  @@map("queues")
}

model CorrectionFactor {
  id String @id @default(uuid())

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  timeSlot  TimeSlot
  visitType VisitType

  correctionFactor  Float
  correctedBaseline Float
  recordCount       Int   @default(0)

  lastUpdated DateTime @updatedAt

  @@unique([doctorProfileId, dayOfWeek, timeSlot, visitType])
  @@index([doctorProfileId, dayOfWeek, timeSlot])
  @@index([doctorProfileId, dayOfWeek])
  @@index([doctorProfileId])
  @@map("correction_factors")
}

model DailyLoadHistory {
  id String @id @default(uuid())

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  recordDate  DateTime  @db.Date
  dayOfWeek   DayOfWeek
  dateOfMonth Int
  month       Int
  weekOfMonth Int

  isPostHoliday    Boolean          @default(false)
  isExamSeason     Boolean          @default(false)
  weatherCondition WeatherCondition @default(UNKNOWN)
  isPostRainDay    Boolean          @default(false)

  totalPatientsActual Int?
  predictedPatients   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorProfileId, recordDate])
  @@index([doctorProfileId, recordDate])
  @@map("daily_load_history")
}

model AppointmentRequest {
  id String @id @default(uuid())

  name          String
  phone         String
  problem       String
  patientAge    Int
  patientGender Gender
  visitType     VisitType         @default(NEW)
  status        AppointmentStatus @default(PENDING)
  preferredDate DateTime          @db.Date

  assignedDoctorId String?
  assignedDoctor   DoctorProfile? @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id], onDelete: SetNull)

  convertedById String?
  convertedBy   User?   @relation("ConvertedByReceptionist", fields: [convertedById], references: [id], onDelete: SetNull)

  queueId              String?   @unique
  queue                Queue?    @relation("TokenFromAppointment", fields: [queueId], references: [id], onDelete: SetNull)
  confirmedTokenNumber Int?
  confirmedDate        DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, preferredDate])
  @@index([phone])
  @@map("appointment_requests")
}

model SystemSettings {
  id                       String   @id @default("singleton")
  driftThreshold           Float    @default(0.30)
  outlierMultiplier        Float    @default(2.0)
  earlyWarningMinutes      Int      @default(15)
  driftCorrectionThreshold Int      @default(10)
  earlyWarningSmsTemplate  String   @default("Hi {patientName}, your token #{tokenNumber} with {doctorName} is coming up. Estimated time: {estimatedTime}.")
  driftSmsTemplate         String   @default("Hi {patientName}, your token #{tokenNumber} with {doctorName} has been delayed. New estimated time: {estimatedTime}.")
  mlTimeout                Int      @default(500)
  holidays                 Json     @default("[]")
  updatedAt                DateTime @updatedAt

  @@map("system_settings")
}
